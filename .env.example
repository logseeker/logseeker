# コピーして .env として使う（例: /opt/loghub/backend/.env）。
# INSTALL.md の systemd unit はこのファイルを EnvironmentFile= として読み込みます。
# cp .env.example .env

# PostgreSQL 接続文字列（INSTALL.md §1 で作成したDB/ユーザー/パスワードに合わせて変更）
DATABASE_URL=postgresql+psycopg://loghub:loghub@127.0.0.1:5432/loghub

# /ingest 認証トークン。空ならローカル検証用に認証なし。
# 外部公開する場合は必ず長いランダム文字列を設定すること（送信側は Authorization: Bearer <token>）。
INGEST_TOKEN=

# GeoIP mmdb の場所（任意。無ければ国コードは常にnullで動作。docs/geoip.md）
GEOIP_DB_PATH=/opt/loghub/backend/geoip/GeoLite2-Country.mmdb

# 取り込みJSON・変換済みJSONの保存場所（親ディレクトリ配下に input/ json/ ioc/ ができる）
JSON_STORE_DIR=/opt/loghub/data/json

# 取り込み最大バイト数（/ingest のリクエストサイズ制限）
MAX_INGEST_BYTES=5242880

# TCP NDJSON 受信ポート（0で無効。INSTALL.md §6でfirewalld開放）
TCP_INGEST_PORT=516
# TCP受信1行あたりの最大バイト数（超過は破棄してdead_letterへ。メモリ枯渇/DoS対策）
TCP_MAX_LINE_BYTES=1048576

# CORS 許可オリジン（カンマ区切り、* で全許可）。本番はフロントのオリジンに絞る。
CORS_ORIGINS=*

# ライセンス（本番はWeb UIの「ライセンス」画面で適用＝DBが正。下記env変数は任意・初回種まき用）
# 署名鍵。空だと開発用の弱い既定値にフォールバックするため、本番は必ず長いランダム文字列に設定する
# （これが漏れる/既定値のままだとライセンスキーを誰でも偽造できてしまう）。
LICENSE_SECRET=
# 初回デプロイ時の種まきキー（任意。空ならUIでキーを貼り付けて適用）。
# 発行（backendのvenvを有効化した状態で）: python -m app.tools.issue_license --tier 2 --days 365 --name "顧客名"
LICENSE_KEY=
# 未適用時の既定（LICENSE方針: 正規ライセンスキー未適用ならWebのみ=tier1・APIオプション無効）。
# 全機能を試したい場合はライセンスキーを発行して適用するか、検証用にのみ一時的に変更すること。
LICENSE_DEFAULT_TIER=1
LICENSE_DEFAULT_API=false

# ログイン必須化（既定false=ログイン不要。外部公開するなら true 推奨。docs/auth.md）
AUTH_REQUIRED=false
# 初回起動時のみ作成される管理者アカウント（ユーザーが1人もいない時のみ有効）。
# 外部公開前に必ず変更するか、初回ログイン後にパスワードを変更すること。
ROOT_USERNAME=logseeker
ROOT_PASSWORD=logseeker
# セッション有効時間（時間）
SESSION_HOURS=12
